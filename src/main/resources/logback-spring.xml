<configuration>
    <property name="LOG_PATTERN"
              value="%d{dd/MM/yyyy - HH:mm} %-5level [%thread] %logger{36}:%line - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <logger name="br.com.senain116.autoescolan116.application.core.usecase" level="DEBUG"/>

    <logger name="org.springframework" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
